<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="https://github.com/avaloniaui/design"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CpuThermalTwinConfigurator"
        x:Class="CpuThermalTwinConfigurator.MainWindow"
        Title="CPU Thermal Twin Configurator"
        Width="750" Height="520"
        mc:Ignorable="d">
  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*" Margin="16">
    <TextBlock Text="Metric Selection" FontSize="22" FontWeight="Bold" />

    <StackPanel Grid.Row="1" Spacing="16">
      <TextBlock Text="Choose which metrics should be enabled for the CPU Thermal Twin system monitor." TextWrapping="Wrap"/>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Content="Save Configuration" Command="{Binding SaveCommand}" Width="150" />
        <Button Content="Load Configuration" Command="{Binding LoadCommand}" Width="150" />
        <Button Content="Reset Defaults" Command="{Binding ResetCommand}" Width="150" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" Spacing="12">
        <!-- OS Metrics Dropdown -->
        <StackPanel Width="230">
          <Button x:Name="OsMetricsButton" Width="230" Height="40" Click="OnOsMetricsButtonClick">
            <TextBlock Text="{Binding OsMetricsButtonText}" TextAlignment="Center"/>
          </Button>
          <Popup IsOpen="{Binding IsOsMetricsOpen, Mode=TwoWay}"
                 PlacementMode="Bottom"
                 PlacementTarget="{Binding #OsMetricsButton}">
            <Border Background="White" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
              <StackPanel Margin="0" Width="230">
                <TextBlock Text="OS Metrics" FontWeight="Bold" Margin="8 8 8 4" />
                <ListBox ItemsSource="{Binding OsMetrics}" Height="300" Margin="0 0 0 8">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Padding="4"/>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>

        <!-- System Metrics Dropdown -->
        <StackPanel Width="230">
          <Button x:Name="SystemMetricsButton" Width="230" Height="40" Click="OnSystemMetricsButtonClick">
            <TextBlock Text="{Binding SystemMetricsButtonText}" TextAlignment="Center"/>
          </Button>
          <Popup IsOpen="{Binding IsSystemMetricsOpen, Mode=TwoWay}"
                 PlacementMode="Bottom"
                 PlacementTarget="{Binding #SystemMetricsButton}">
            <Border Background="White" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
              <StackPanel Margin="0" Width="230">
                <TextBlock Text="System Metrics" FontWeight="Bold" Margin="8 8 8 4" />
                <ListBox ItemsSource="{Binding SystemMetrics}" Height="300" Margin="0 0 0 8">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Padding="4"/>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>

        <!-- CPU Metrics Dropdown -->
        <StackPanel Width="230">
          <Button x:Name="CpuMetricsButton" Width="230" Height="40" Click="OnCpuMetricsButtonClick">
            <TextBlock Text="{Binding CpuMetricsButtonText}" TextAlignment="Center"/>
          </Button>
          <Popup IsOpen="{Binding IsCpuMetricsOpen, Mode=TwoWay}"
                 PlacementMode="Bottom"
                 PlacementTarget="{Binding #CpuMetricsButton}">
            <Border Background="White" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
              <StackPanel Margin="0" Width="230">
                <TextBlock Text="CPU Metrics" FontWeight="Bold" Margin="8 8 8 4" />
                <ListBox ItemsSource="{Binding CpuMetrics}" Height="300" Margin="0 0 0 8">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Padding="4"/>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>
      </StackPanel>

      <TextBlock Text="Status:" FontWeight="Bold"/>
      <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/> 
    </StackPanel>
  </Grid>
</Window>
